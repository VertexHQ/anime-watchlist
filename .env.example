# Google Apps Script web app URL (deploy as Web App → Anyone)
VITE_SHEETS_SCRIPT_URL=

# Google Spreadsheet ID (from the sheet URL: docs.google.com/spreadsheets/d/<ID>/edit)
VITE_SPREADSHEET_ID=

# Sheet tab names (only change if you rename the tabs in Google Sheets)
VITE_SHEET_WATCHING=watching
VITE_SHEET_COMPLETED=completed
VITE_SHEET_PLAN=plan
VITE_SHEET_UPCOMING=upcoming
